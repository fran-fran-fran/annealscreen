<?xml version="1.0"?>
<!-- AnnealScreen Home Panel
     The main (and only) panel. Uses flex layout with proportional sizing.
     Left sidebar for profiles/controls, right area for chart and status.
     Edit this file to customize the layout — no rebuild needed. -->
<component>
  <view name="home_panel"
        extends="lv_obj" width="100%" height="100%"
        style_pad_all="#space_md" style_pad_gap="#space_md"
        flex_flow="row" scrollable="false">

    <!-- Left sidebar: profiles + controls -->
    <lv_obj name="sidebar"
            width="30%" height="100%"
            flex_flow="column" style_pad_all="0" style_pad_gap="#space_sm"
            scrollable="false">

      <!-- Section header -->
      <lv_label text="Profiles" style_pad_left="#space_sm"/>

      <!-- Profile list: scrollable container, flex-grow fills space -->
      <lv_obj name="annealr_profile_list"
              width="100%" style_flex_grow="1"
              flex_flow="column" style_pad_all="#space_xs" style_pad_gap="#space_xs"
              style_radius="#border_radius"/>

      <!-- Status text -->
      <lv_label name="status_label"
                width="100%" bind_text="annealr_status_text"/>

      <!-- Control buttons -->
      <lv_obj name="button_row"
              width="100%" height="content"
              flex_flow="column" style_pad_all="0" style_pad_gap="#space_xs"
              scrollable="false">

        <lv_button name="btn_start" width="100%">
          <lv_label text="Start"/>
          <bind_flag_if_eq subject="annealr_can_start" flag="hidden" ref_value="0"/>
          <event_cb trigger="clicked" callback="on_annealr_start"/>
        </lv_button>

        <lv_button name="btn_pause" width="100%">
          <lv_label text="Pause"/>
          <bind_flag_if_eq subject="annealr_can_pause" flag="hidden" ref_value="0"/>
          <event_cb trigger="clicked" callback="on_annealr_pause"/>
        </lv_button>

        <lv_button name="btn_resume" width="100%">
          <lv_label text="Resume"/>
          <bind_flag_if_eq subject="annealr_can_resume" flag="hidden" ref_value="0"/>
          <event_cb trigger="clicked" callback="on_annealr_resume"/>
        </lv_button>

        <lv_button name="btn_cancel" width="100%">
          <lv_label text="Cancel"/>
          <bind_flag_if_eq subject="annealr_can_cancel" flag="hidden" ref_value="0"/>
          <event_cb trigger="clicked" callback="on_annealr_cancel"/>
        </lv_button>
      </lv_obj>
    </lv_obj>

    <!-- Right area: chart + info bar -->
    <lv_obj name="main_area"
            height="100%" style_flex_grow="1"
            flex_flow="column" style_pad_all="0" style_pad_gap="#space_sm"
            scrollable="false">

      <!-- Temperature chart canvas -->
      <lv_obj name="annealr_chart"
              width="100%" style_flex_grow="1"
              style_radius="#border_radius"/>

      <!-- Bottom info bar -->
      <lv_obj name="info_bar"
              width="100%" height="content"
              flex_flow="row" style_pad_all="#space_sm" style_pad_gap="#space_lg"
              style_flex_main_place="space_evenly" style_flex_cross_place="center"
              style_radius="#border_radius" scrollable="false">

        <lv_obj width="content" height="content"
                flex_flow="row" style_pad_gap="#space_xs"
                style_flex_cross_place="center" scrollable="false">
          <lv_label text="Chamber:"/>
          <lv_label name="chamber_temp_label" bind_text="annealr_chamber_temp"/>
        </lv_obj>

        <lv_obj width="content" height="content"
                flex_flow="row" style_pad_gap="#space_xs"
                style_flex_cross_place="center" scrollable="false">
          <lv_label text="Stage:"/>
          <lv_label name="stage_label" bind_text="annealr_stage_label"/>
        </lv_obj>

        <lv_obj width="content" height="content"
                flex_flow="row" style_pad_gap="#space_xs"
                style_flex_cross_place="center" scrollable="false">
          <lv_label text="Profile:"/>
          <lv_label name="profile_label" bind_text="annealr_profile_name"/>
        </lv_obj>
      </lv_obj>
    </lv_obj>
  </view>
</component>