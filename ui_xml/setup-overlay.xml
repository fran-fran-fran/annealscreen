<!--
  AnnealScreen Setup Overlay
  ===========================
  Shown on first launch when no settings.json exists.
  Collects Moonraker host/port and heater name, then saves.

  This is a simple centered card — no navigation stack needed.
-->
<component>
    <!-- Full-screen semi-transparent backdrop -->
    <lv_obj name="setup_root"
        width="100%"
        height="100%"
        style_bg_color="#overlay_bg"
        style_bg_opa="220"
        style_flex_flow="column"
        style_flex_main_place="center"
        style_flex_cross_place="center"
        style_border_width="0"
    >
        <!-- Setup card -->
        <lv_obj name="setup_card"
            width="70%"
            height="content"
            styles="card"
            style_flex_flow="column"
            style_pad_all="#space_xl"
            style_pad_gap="#space_md"
            style_max_width="500"
        >
            <lv_label text="AnnealScreen Setup"
                width="100%"
                style_text_font="font_heading"
                style_text_color="#text"
                style_text_align="center"
            />

            <!-- Divider -->
            <lv_obj width="100%" height="1" styles="divider"/>

            <!-- Moonraker host -->
            <lv_label text="Moonraker Host"
                style_text_color="#text_muted"
                style_text_font="font_small"
            />
            <lv_textarea name="setup_host"
                width="100%"
                placeholder_text="e.g. 192.168.1.100 or localhost"
                one_line="true"
                style_bg_color="#elevated_bg"
                style_text_color="#text"
                style_border_color="#border"
                style_border_width="1"
                style_radius="4"
            />

            <!-- Moonraker port -->
            <lv_label text="Moonraker Port"
                style_text_color="#text_muted"
                style_text_font="font_small"
            />
            <lv_textarea name="setup_port"
                width="100%"
                placeholder_text="7125"
                one_line="true"
                accepted_chars="0123456789"
                style_bg_color="#elevated_bg"
                style_text_color="#text"
                style_border_color="#border"
                style_border_width="1"
                style_radius="4"
            />

            <!-- Heater name -->
            <lv_label text="Heater Name"
                style_text_color="#text_muted"
                style_text_font="font_small"
            />
            <lv_textarea name="setup_heater"
                width="100%"
                placeholder_text="e.g. annealer"
                one_line="true"
                style_bg_color="#elevated_bg"
                style_text_color="#text"
                style_border_color="#border"
                style_border_width="1"
                style_radius="4"
            />

            <!-- Spacer -->
            <lv_obj width="1" height="#space_sm"
                style_bg_opa="0" style_border_width="0"/>

            <!-- Button row -->
            <lv_obj width="100%" height="content"
                style_flex_flow="row"
                style_flex_main_place="end"
                style_pad_gap="#space_md"
                style_bg_opa="0"
                style_border_width="0"
            >
                <lv_button name="btn_setup_save"
                    styles="btn_primary"
                >
                    <lv_label text="Connect" style_text_color="#text"/>
                    <event_cb trigger="clicked" callback="on_setup_save"/>
                </lv_button>
            </lv_obj>
        </lv_obj>
    </lv_obj>
</component>
