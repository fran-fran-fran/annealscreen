<?xml version="1.0"?>
<!-- AnnealScreen Setup Overlay — first-run configuration.
     Collects Moonraker host/port and heater name. -->
<component>
  <view name="setup_overlay"
        extends="lv_obj" width="100%" height="100%"
        flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
        scrollable="false">

    <!-- Setup card -->
    <lv_obj name="setup_card"
            width="70%" height="content"
            flex_flow="column" style_pad_all="#space_xl" style_pad_gap="#space_md"
            style_max_width="500" style_radius="#border_radius">

      <lv_label text="AnnealScreen Setup" width="100%" style_text_align="center"/>

      <!-- Moonraker host -->
      <lv_label text="Moonraker Host"/>
      <lv_textarea name="setup_host"
                   width="100%" placeholder_text="e.g. 192.168.1.100 or localhost"
                   one_line="true"/>

      <!-- Moonraker port -->
      <lv_label text="Moonraker Port"/>
      <lv_textarea name="setup_port"
                   width="100%" placeholder_text="7125"
                   one_line="true" accepted_chars="0123456789"/>

      <!-- Heater name -->
      <lv_label text="Heater Name"/>
      <lv_textarea name="setup_heater"
                   width="100%" placeholder_text="e.g. annealer"
                   one_line="true"/>

      <!-- Button row -->
      <lv_obj width="100%" height="content"
              flex_flow="row" style_flex_main_place="end" style_pad_gap="#space_md"
              scrollable="false">
        <lv_button name="btn_setup_save">
          <lv_label text="Connect"/>
          <event_cb trigger="clicked" callback="on_setup_save"/>
        </lv_button>
      </lv_obj>
    </lv_obj>
  </view>
</component>