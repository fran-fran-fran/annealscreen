<?xml version="1.0"?>
<!-- AnnealScreen globals.xml — Design tokens and shared constants.
     Edit this file to change the application's look without rebuilding.
     Colors are also registered from config/themes/dark.json at runtime. -->
<component>
  <consts>
    <!-- Spacing tokens (800x480 reference display) -->
    <px name="space_xxs" value="2"/>
    <px name="space_xs" value="4"/>
    <px name="space_sm" value="6"/>
    <px name="space_md" value="10"/>
    <px name="space_lg" value="14"/>
    <px name="space_xl" value="18"/>
    <px name="space_2xl" value="24"/>

    <!-- Layout tokens -->
    <px name="border_radius" value="8"/>
    <px name="button_height" value="42"/>
    <px name="header_height" value="44"/>
  </consts>
</component>